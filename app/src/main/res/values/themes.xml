<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal de la aplicación -->
    <style name="Theme.CacaoClassifier" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Tema para el Splash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- El ícono que se mostrará en el centro -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        
        <!-- Opcional: El color de fondo de la pantalla -->
        <item name="windowSplashScreenBackground">@color/splash_background</item> <!-- Usaremos un color personalizado -->

        <!-- El tema que se aplicará después de que el splash screen termine -->
        <item name="postSplashScreenTheme">@style/Theme.CacaoClassifier</item>
    </style>
</resources>
